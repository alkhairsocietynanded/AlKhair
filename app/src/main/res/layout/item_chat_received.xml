<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="16dp"
    android:paddingEnd="60dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <LinearLayout
        android:id="@+id/chatBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:background="@drawable/bg_chat_bubble_received"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:orientation="vertical"
        android:elevation="1dp"
        android:maxWidth="280dp">

        <!-- Sender Name (visible in group chats) -->
        <TextView
            android:id="@+id/tvSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sender Name"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold" />

        <!-- ═══ IMAGE MEDIA — WhatsApp-style placeholder + overlay ═══ -->
        <FrameLayout
            android:id="@+id/flImageContainer"
            android:layout_width="240dp"
            android:layout_height="180dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <!-- Actual image (shown after download) -->
            <ImageView
                android:id="@+id/ivMedia"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Attached image"
                android:background="@drawable/bg_rounded_card" />

            <!-- Download overlay (shown when NOT downloaded) -->
            <FrameLayout
                android:id="@+id/ivMediaOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#AA000000"
                android:visibility="gone">

                <!-- Download icon — tapping this triggers download -->
                <ImageView
                    android:id="@+id/ivDownloadIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_download"
                    android:visibility="visible"
                    android:importantForAccessibility="no"
                    app:tint="@android:color/white" />

                <!-- ProgressBar — shown while download in progress -->
                <ProgressBar
                    android:id="@+id/pbImageDownload"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="@android:color/white"
                    android:visibility="gone" />

            </FrameLayout>

        </FrameLayout>

        <!-- ═══ DOCUMENT ROW — WhatsApp-style placeholder + overlay ═══ -->
        <LinearLayout
            android:id="@+id/llDocument"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <!-- Download icon for document (replaced by attachment icon after download) -->
            <ImageView
                android:id="@+id/ivDocIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_download"
                app:tint="?attr/colorPrimary"
                android:importantForAccessibility="no" />

            <!-- ProgressBar for document download -->
            <ProgressBar
                android:id="@+id/pbDocDownload"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:indeterminateTint="?attr/colorPrimary"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDocumentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:maxWidth="180dp"
                android:maxLines="1"
                android:ellipsize="middle"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorPrimary"
                android:text="document.pdf" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvMessageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Message text"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="2dp"
            android:text="12:30 PM"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:alpha="0.7" />

    </LinearLayout>

</FrameLayout>
